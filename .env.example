# Server-side config for the self-hosted deploy.
# Copy to .env on the server (cp .env.example .env) and fill in real values.
# .env is gitignored — never commit real secrets.

# Notion internal-integration secret used by /api/publish (starts with "secret_"
# or "ntn_"). Without it, the publish-to-Notion modal reports "not connected".
NOTION_TOKEN=

# Where published pages go — set EXACTLY ONE of the two below:
#   • a database id  -> each publish is a new row in that database
NOTION_PARENT_DATABASE_ID=
#   • OR a page id   -> each publish is a sub-page of that page
NOTION_PARENT_PAGE_ID=

# Port the container listens on (nginx proxies to this). Default 3001.
PORT=3001
